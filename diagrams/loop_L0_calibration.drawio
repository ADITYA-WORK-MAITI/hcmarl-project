<mxfile host="app.diagrams.net">
  <diagram id="L0" name="L0 Calibration">
    <mxGraphModel dx="1400" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="L0: Offline Calibration &amp; Constraint Inference  (runs once before training)" style="text;html=1;fontSize=14;fontStyle=1;align=center;fontColor=#6A1B9A;" vertex="1" parent="1">
          <mxGeometry x="100" y="15" width="1200" height="25" as="geometry"/>
        </mxCell>

        <!-- Col 1: Dataset -->
        <mxCell id="c1" value="&lt;b&gt;1. Real Dataset&lt;/b&gt;&lt;br&gt;WSD4FESDRM&lt;br&gt;34 subjects&lt;br&gt;Borg-RPE-20 shoulder rotation&lt;br&gt;30–60% MVIC&lt;br&gt;Zenodo 8415066, Sci. Data 2024" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="200" height="110" as="geometry"/>
        </mxCell>

        <!-- Col 2: Calibration -->
        <mxCell id="c2" value="&lt;b&gt;2. 3CC-r Calibration (Path G)&lt;/b&gt;&lt;br&gt;&lt;i&gt;§3.5 · Eq.(6)&lt;/i&gt;&lt;br&gt;&lt;br&gt;Grid-search (F, R) per subject&lt;br&gt;Minimise |ET_obs − ET_pred|&lt;br&gt;Forward-simulate 3CC-r ODE&lt;br&gt;Output: (F, R, r) per muscle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="60" width="220" height="110" as="geometry"/>
        </mxCell>

        <!-- Col 3: Demo Collection -->
        <mxCell id="c3" value="&lt;b&gt;3. Demo Collection&lt;/b&gt;&lt;br&gt;&lt;br&gt;Run calibrated ODE per subject&lt;br&gt;at their %MVIC level&lt;br&gt;Collect τ = {(o_i, a_i)}&lt;br&gt;Per-agent rollouts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="570" y="60" width="200" height="110" as="geometry"/>
        </mxCell>

        <!-- Col 4: MMICRL -->
        <mxCell id="c4" value="&lt;b&gt;4. MMICRL Constraint Inference&lt;/b&gt;&lt;br&gt;&lt;i&gt;§4 · Eq.(9)–(11)&lt;/i&gt;&lt;br&gt;&lt;br&gt;EM loop (n_iterations epochs):&lt;br&gt;  M-step: train CFDE flow p(s,a|z)&lt;br&gt;  E-step: reassign z via p(z|τ)&lt;br&gt;CFDE = MADE/MAF normalising flows&lt;br&gt;λ₁ = λ₂ ⇒ pure MI  [Eq.11]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="830" y="60" width="250" height="110" as="geometry"/>
        </mxCell>

        <!-- Col 5: Output -->
        <mxCell id="c5" value="&lt;b&gt;5. Output → L1–L4&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-type θ_max(z)&lt;br&gt;Personalised safety ceilings&lt;br&gt;per muscle per worker type&lt;br&gt;Constraint network (BCE)&lt;br&gt;Type assignments" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1140" y="60" width="200" height="110" as="geometry"/>
        </mxCell>

        <!-- EM loop dashed box -->
        <mxCell id="em_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=none;strokeColor=#6A1B9A;strokeWidth=1.5;dashed=1;dashPattern=8 4;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="820" y="48" width="270" height="132" as="geometry"/>
        </mxCell>
        <mxCell id="em_label" value="EM loop" style="text;html=1;fontSize=9;fontColor=#6A1B9A;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="900" y="48" width="80" height="14" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="a12" value="ET_obs, %MVIC" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c1" target="c2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a23" value="(F, R, r)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c2" target="c3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a34" value="τ demos" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c3" target="c4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a45" value="θ_max(z)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c4" target="c5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Param Table -->
        <mxCell id="ptable" value="&lt;b&gt;Calibrated parameters&lt;/b&gt; [Table 1, Frey-Law, Looft &amp; Heitsman 2012]:&lt;br&gt;Shoulder: F=0.0146, R=0.00058, r=15  |  Ankle: F=0.00589, R=0.0182, r=15  |  Knee: F=0.0150, R=0.00175, r=15&lt;br&gt;Elbow: F=0.00912, R=0.00094, r=15  |  &lt;b&gt;Trunk: F=0.00657, R=0.00354, r=15&lt;/b&gt;  |  Grip: F=0.00794, R=0.00109, r=30" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#999;fontSize=9;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="210" width="1310" height="55" as="geometry"/>
        </mxCell>

        <!-- Section refs -->
        <mxCell id="refs" value="Math doc refs:  data = Sci. Data 2024 (Zenodo 8415066)  |  calibration = §3.5  |  MMICRL = §4, Eq.9-11  |  CFDE = Qiao+ NeurIPS 2023  |  constraint network = BCE loss on p(constraint | s,a,z)" style="text;html=1;fontSize=9;fontColor=#888;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="280" width="1310" height="18" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>