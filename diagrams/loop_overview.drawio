<mxfile host="app.diagrams.net">
  <diagram id="overview" name="Loop Nesting Overview">
    <mxGraphModel dx="1400" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="t1" value="HC-MARL Architecture — Loop Nesting Overview" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="1000" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="5 loops, 3 nesting levels. Each loop has its own detailed diagram (L0–L4)." style="text;html=1;fontSize=11;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="200" y="38" width="1000" height="20" as="geometry"/>
        </mxCell>

        <!-- L0 Panel -->
        <mxCell id="L0_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="1280" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="L0_title" value="&lt;b&gt;L0: Offline Calibration &amp; MMICRL&lt;/b&gt;  (runs once)" style="text;html=1;fontSize=13;fontColor=#E65100;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="72" width="1280" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="L0_flow" value="Real Data (WSD4FESDRM)  →  3CC-r Calibration (Path G, §3.5)  →  Demo Collection  →  MMICRL EM (§4, Eq.9-11)  →  θ_max(z), (F,R,r) per muscle" style="text;html=1;fontSize=10;align=center;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="1280" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow L0 to L1 -->
        <mxCell id="a_L0_L1" value="params" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="L0_bg" target="L1_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- L1 Panel -->
        <mxCell id="L1_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="1280" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="L1_title" value="&lt;b&gt;L1: Training Loop&lt;/b&gt;  (while global_step &lt; 5M, repeated across 5 seeds)" style="text;html=1;fontSize=12;fontColor=#1565C0;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="175" width="600" height="22" as="geometry"/>
        </mxCell>

        <!-- Episode Reset -->
        <mxCell id="ep_reset" value="&lt;b&gt;Episode Reset&lt;/b&gt;&lt;br&gt;env.reset()&lt;br&gt;MR=1, MA=0, MF=0&lt;br&gt;obs_0, global_state_0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="230" width="170" height="80" as="geometry"/>
        </mxCell>

        <!-- L2 Panel -->
        <mxCell id="L2_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E0F2F1;strokeColor=#00695C;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="290" y="210" width="620" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="L2_title" value="&lt;b&gt;L2: Episode Loop&lt;/b&gt;  (for step in max_steps)" style="text;html=1;fontSize=11;fontColor=#00695C;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="290" y="213" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- L3 Panel inside L2 -->
        <mxCell id="L3_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=1.5;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="310" y="240" width="580" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="L3_title" value="&lt;b&gt;L3: Control Pipeline&lt;/b&gt; (per env step)" style="text;html=1;fontSize=10;fontColor=#E65100;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="310" y="243" width="300" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="L3_flow" value="Observe x_i → NSWF allocate j*(i) [§6] → Load T_L [§7.1] → Actor C_nom [§7.2] → ECBF-QP C* [§5] → ODE x(t+1) [§3.2]" style="text;html=1;fontSize=9;align=center;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="310" y="265" width="580" height="20" as="geometry"/>
        </mxCell>

        <!-- L3 feedback arrow label -->
        <mxCell id="L3_fb" value="x(t+1) → next step" style="text;html=1;fontSize=9;fontColor=#00695C;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="450" y="295" width="150" height="18" as="geometry"/>
        </mxCell>

        <!-- Reward/Cost row -->
        <mxCell id="rc_row" value="R_t = Σ_i ln(U(i,j*(i)) − D_i)  [Eq.33]   |   C_t = Σ max(0, MF − θ_max)   |   Store to rollout buffer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="330" y="390" width="560" height="40" as="geometry"/>
        </mxCell>

        <!-- Arrow L2 reward down -->
        <mxCell id="a_L3_rc" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#555;strokeWidth=1.2;" edge="1" parent="1" source="L3_bg" target="rc_row">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- L4 Panel -->
        <mxCell id="L4_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="960" y="210" width="340" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="L4_title" value="&lt;b&gt;L4: MAPPO-Lagrangian&lt;/b&gt;" style="text;html=1;fontSize=11;fontColor=#2E7D32;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="213" width="250" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="L4_body" value="10 PPO epochs × minibatches&lt;br&gt;&lt;br&gt;&lt;b&gt;Actor:&lt;/b&gt; L = −min(rÂ, clip·Â)&lt;br&gt;        + λ·max(cost surr) − β·H&lt;br&gt;&lt;b&gt;Critic:&lt;/b&gt; V_φ(s) 2×128 Tanh&lt;br&gt;&lt;b&gt;Cost-Critic:&lt;/b&gt; V_c(s) same arch&lt;br&gt;&lt;b&gt;Lambda:&lt;/b&gt; dual ascent on log λ&lt;br&gt;  ↑λ if cost &gt; budget (0.10)&lt;br&gt;&lt;br&gt;batch=256, lr=3e-4, grad-clip=0.5" style="text;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=12;spacingTop=4;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="965" y="238" width="330" height="170" as="geometry"/>
        </mxCell>

        <!-- Arrow ep_reset to L2 -->
        <mxCell id="a_er_L2" value="obs_0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="ep_reset" target="L2_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow L2 buffer to L4 -->
        <mxCell id="a_L2_L4" value="buffer" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;exitX=1;exitY=0.4;entryX=0;entryY=0.4;" edge="1" parent="1" source="L2_bg" target="L4_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Return arrow: L4 back to ep_reset (L1 loop) -->
        <mxCell id="a_loop1" value="L1 loop: next episode with updated θ" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#C62828;strokeWidth=1.8;dashed=1;dashPattern=10 5;fontSize=9;fontColor=#C62828;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" parent="1" source="L4_bg" target="ep_reset">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1130" y="560"/>
              <mxPoint x="165" y="560"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Metrics box -->
        <mxCell id="metrics" value="&lt;b&gt;9-Metric Logger (O1–O9)&lt;/b&gt;&lt;br&gt;violation_rate · safety_rate · jain_fairness&lt;br&gt;tasks_completed · cum_reward · peak_fatigue&lt;br&gt;forced_rest_rate · constraint_recovery_t · cum_cost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#888;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="480" width="280" height="70" as="geometry"/>
        </mxCell>

        <!-- Arrow rc to metrics -->
        <mxCell id="a_rc_met" value="ep metrics" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#888;strokeWidth=1.2;fontSize=9;" edge="1" parent="1" source="rc_row" target="metrics">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Footer -->
        <mxCell id="footer" value="Section refs:  L0 = §3.5, §4  |  L2 = §7.3 (pipeline steps 1–7)  |  L3 = §5–6  |  L4 = CMDP (Achiam+ 2017)  |  All 4 errors from v1 corrected: θ_max vs δ_max, Trunk F, reward log-surplus, global-state dim" style="text;html=1;fontSize=9;fontColor=#888;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="630" width="1280" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="footer2" value="Key: δ_max = R/(F+R) is the sustainability bound [Eq.6], NOT θ_max.  θ_max is a design parameter with lower bound F/(F+Rr) [Def. 5.4, Eq.25]." style="text;html=1;fontSize=9;fontColor=#C62828;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="650" width="1280" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>