<mxfile host="app.diagrams.net">
  <diagram id="L1" name="L1 Training Loop">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ==================== COLUMN 1: INPUT MODULE ==================== -->
        <mxCell id="h1" value="INPUT MODULE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9D9D9;strokeColor=#333;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r1a" value="&lt;b&gt;From L0: Calibrated Params&lt;/b&gt;&lt;br&gt;• (F, R, r) per muscle group&lt;br&gt;• Table 1 values [§3.5]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="20" y="50" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="r1b" value="&lt;b&gt;From L0: Safety Thresholds&lt;/b&gt;&lt;br&gt;• θ_max(z) per worker type&lt;br&gt;• Per muscle personalised ceilings&lt;br&gt;• Constraint network weights" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="20" y="110" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r1c" value="&lt;b&gt;Training Config&lt;/b&gt;&lt;br&gt;• total_steps = 5M&lt;br&gt;• n_workers = 6 (default)&lt;br&gt;• max_steps per episode&lt;br&gt;• 5 seeds (independent runs)&lt;br&gt;• method: hcmarl / mappo / ippo / mappo_lag" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="20" y="180" width="220" height="100" as="geometry"/>
        </mxCell>

        <!-- ==================== COLUMN 2: EPISODE MODULE ==================== -->
        <mxCell id="h2" value="EPISODE MODULE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9D9D9;strokeColor=#333;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="20" width="240" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r2a" value="&lt;b&gt;E1: Episode Reset&lt;/b&gt;&lt;br&gt;• env.reset()&lt;br&gt;• Init MR=1, MA=0, MF=0&lt;br&gt;  per worker per muscle&lt;br&gt;• Generate obs_0, global_state_0" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="290" y="50" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r2b" value="&lt;b&gt;E2: Run Episode = Loop 2 (L2)&lt;/b&gt;&lt;br&gt;• for step in range(max_steps)&lt;br&gt;• Contains Loop 3 (L3): NSWF + ECBF&lt;br&gt;• Fills rollout buffer&lt;br&gt;• See Figure L2 for detail" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="290" y="140" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r2c" value="&lt;b&gt;E3: Episode Termination&lt;/b&gt;&lt;br&gt;• Break if all workers terminated&lt;br&gt;• Or max_steps reached&lt;br&gt;• global_step += episode_steps" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="290" y="230" width="240" height="70" as="geometry"/>
        </mxCell>

        <!-- ==================== COLUMN 3: LEARNING MODULE ==================== -->
        <mxCell id="h3" value="LEARNING MODULE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9D9D9;strokeColor=#333;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="580" y="20" width="240" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r3a" value="&lt;b&gt;U1: PPO Update = Loop 4 (L4)&lt;/b&gt;&lt;br&gt;• 10 PPO epochs × minibatches&lt;br&gt;• Actor + Value Critic + Cost Critic&lt;br&gt;• See Figure L4 for detail" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="580" y="50" width="240" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="r3b" value="&lt;b&gt;U2: Lagrangian λ Update&lt;/b&gt;&lt;br&gt;• cost_ema = EMA of episode cost&lt;br&gt;• Δ log λ ∝ −(cost_ema − budget)&lt;br&gt;• budget = 0.10&lt;br&gt;• ↑ λ if too many violations&lt;br&gt;• ↓ λ otherwise" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="580" y="125" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="r3c" value="&lt;b&gt;U3: Weight Update Output&lt;/b&gt;&lt;br&gt;• Updated θ (actor)&lt;br&gt;• Updated φ (value critic)&lt;br&gt;• Updated φ_c (cost critic)&lt;br&gt;→ Back to E1 for next episode" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="580" y="225" width="240" height="85" as="geometry"/>
        </mxCell>

        <!-- ==================== COLUMN 4: EVALUATION MODULE ==================== -->
        <mxCell id="h4" value="EVALUATION MODULE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9D9D9;strokeColor=#333;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="870" y="20" width="240" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r4a" value="&lt;b&gt;O1: violation_rate&lt;/b&gt;&lt;br&gt;• cost / (steps × workers)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="870" y="50" width="240" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="r4b" value="&lt;b&gt;O2: safety_rate&lt;/b&gt;&lt;br&gt;• safe_steps / total_steps" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="870" y="85" width="240" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="r4c" value="&lt;b&gt;O3: jain_fairness&lt;/b&gt;&lt;br&gt;• Jain's index on tasks_per_worker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="870" y="120" width="240" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="r4d" value="&lt;b&gt;O4: tasks_completed&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="870" y="155" width="240" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r4e" value="&lt;b&gt;O5: cumulative_reward&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="870" y="180" width="240" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r4f" value="&lt;b&gt;O6: peak_fatigue&lt;/b&gt;&lt;br&gt;• max MF across all workers, muscles" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="870" y="205" width="240" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="r4g" value="&lt;b&gt;O7: forced_rest_rate&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="870" y="240" width="240" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r4h" value="&lt;b&gt;O8: constraint_recovery_time&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="870" y="265" width="240" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r4i" value="&lt;b&gt;O9: cumulative_cost&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="870" y="290" width="240" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r4j" value="&lt;b&gt;Checkpoint&lt;/b&gt;&lt;br&gt;• Save if best reward&lt;br&gt;• Eval at eval_interval" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="870" y="315" width="240" height="50" as="geometry"/>
        </mxCell>

        <!-- ==================== ARROWS ==================== -->
        <mxCell id="a1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" parent="1" source="r1a" target="r2a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a1b" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r1b" target="r2b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r2b" target="r3a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2b" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r2c" target="r3b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r3c" target="r4a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== CAPTION ==================== -->
        <mxCell id="cap" value="&lt;b&gt;Figure L1:&lt;/b&gt; Schematic framework of the training loop (Loop 1). The outermost online loop iterates episodes until 5M total env steps. Each episode runs Loop 2 (env steps containing Loop 3 = NSWF + ECBF), then Loop 4 (PPO-Lagrangian update). The evaluation module logs 9 metrics per episode and checkpoints the best model. Training uses 5 independent seeds. Pipeline structure follows §7.3." style="text;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=5;spacingTop=3;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="20" y="400" width="1090" height="45" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>