<mxfile host="app.diagrams.net">
  <diagram id="L4" name="L4 MAPPO-Lagrangian">
    <mxGraphModel dx="1400" dy="550" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="550" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="L4: MAPPO-Lagrangian Policy Update  (10 epochs, end of each episode in L1)" style="text;html=1;fontSize=13;fontStyle=1;align=center;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="100" y="12" width="1200" height="25" as="geometry"/>
        </mxCell>

        <!-- Col 1: Buffer -->
        <mxCell id="c1" value="&lt;b&gt;1. Rollout Buffer&lt;/b&gt;&lt;br&gt;&lt;br&gt;(o_i, s, a, log π,&lt;br&gt;R_t, C_t, done)&lt;br&gt;from L2 episode&lt;br&gt;&lt;br&gt;Flat: T × N samples&lt;br&gt;(T = steps, N = workers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="185" height="130" as="geometry"/>
        </mxCell>

        <!-- Col 2: GAE -->
        <mxCell id="c2" value="&lt;b&gt;2. Compute GAE&lt;/b&gt;&lt;br&gt;&lt;br&gt;δ_t = R_t + γ·V(s_{t+1}) − V(s_t)&lt;br&gt;Â_t = Σ (γ·λ_GAE)^k · δ_{t+k}&lt;br&gt;γ = 0.99, λ_GAE = 0.95&lt;br&gt;&lt;br&gt;Same for &lt;b&gt;cost&lt;/b&gt; advantages&lt;br&gt;(separate cost-critic V_c)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="270" y="60" width="210" height="130" as="geometry"/>
        </mxCell>

        <!-- Col 3: PPO Epochs -->
        <mxCell id="c3" value="&lt;b&gt;3. PPO Epochs (inner loop)&lt;/b&gt;&lt;br&gt;&lt;br&gt;For each of 10 epochs:&lt;br&gt;  ratio r = π_new / π_old&lt;br&gt;  &lt;b&gt;L_actor&lt;/b&gt; = −min(r·Â, clip(r)·Â)&lt;br&gt;           + λ · max(cost surr_1, surr_2)&lt;br&gt;           − 0.01 · H(π)&lt;br&gt;  Backprop + grad clip (0.5)&lt;br&gt;  batch = 256, lr = 3e-4, ε = 0.2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#1B5E20;strokeWidth=2;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="535" y="60" width="260" height="130" as="geometry"/>
        </mxCell>

        <!-- Col 4: Critics -->
        <mxCell id="c4" value="&lt;b&gt;4. Critic Updates&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Value critic V_φ(s):&lt;/b&gt;&lt;br&gt;2×128 Tanh → scalar V(s)&lt;br&gt;L_critic = MSE(V, returns)&lt;br&gt;&lt;br&gt;&lt;b&gt;Cost critic V_c(s):&lt;/b&gt;&lt;br&gt;2×128 Tanh → scalar&lt;br&gt;L_ccrit = MSE(V_c, cost returns)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="850" y="60" width="220" height="130" as="geometry"/>
        </mxCell>

        <!-- Col 5: Lambda -->
        <mxCell id="c5" value="&lt;b&gt;5. Lambda Dual Ascent&lt;/b&gt;&lt;br&gt;&lt;br&gt;log λ ∈ nn.Parameter&lt;br&gt;cost_ema = EMA of ep cost&lt;br&gt;(α_ema = 0.05)&lt;br&gt;&lt;br&gt;Δ log λ ∝ −(cost_ema − budget)&lt;br&gt;budget = 0.10&lt;br&gt;&lt;br&gt;↑ λ if MF &gt; θ_max (too costly)&lt;br&gt;↓ λ otherwise" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1125" y="60" width="210" height="130" as="geometry"/>
        </mxCell>

        <!-- Forward arrows -->
        <mxCell id="a12" value="transitions" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c1" target="c2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a23" value="Â_t, returns" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c2" target="c3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a34" value="actor grad" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c3" target="c4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a45" value="V, V_c" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c4" target="c5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 10-epoch loop arrow -->
        <mxCell id="epoch_loop" value="10 epochs (n_epochs iterations)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#C62828;strokeWidth=1.6;dashed=1;dashPattern=8 4;fontSize=9;fontColor=#C62828;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" parent="1" source="c5" target="c3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1230" y="260"/>
              <mxPoint x="665" y="260"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Output box -->
        <mxCell id="out" value="&lt;b&gt;Output:&lt;/b&gt; Updated weights θ (actor), φ (critic) → back to L2 next episode (closes L1 iteration)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#1B5E20;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="320" width="600" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_out" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#1B5E20;strokeWidth=1.5;exitX=0.5;exitY=1;" edge="1" parent="1" source="c3" target="out">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Refs -->
        <mxCell id="refs" value="Math doc refs:  MAPPO-Lagrangian = Achiam+ 2017 (CMDP) + PPO  |  GAE = Schulman+ 2015  |  dual ascent on λ  |  cost surrogates: max(r₁,r₂) errs toward safety under ratio truncation  |  cost advantages NOT normalised (Stooke+ 2020)" style="text;html=1;fontSize=9;fontColor=#888;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="380" width="1300" height="18" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>