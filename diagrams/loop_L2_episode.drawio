<mxfile host="app.diagrams.net">
  <diagram id="L2" name="L2 Episode Loop">
    <mxGraphModel dx="1500" dy="650" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="650" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="L2: Episode Loop  (for step in range(max_steps), inside L1)" style="text;html=1;fontSize=14;fontStyle=1;align=center;fontColor=#00695C;" vertex="1" parent="1">
          <mxGeometry x="100" y="12" width="1300" height="25" as="geometry"/>
        </mxCell>

        <!-- L3 dashed border -->
        <mxCell id="L3_border" value="" style="rounded=1;whiteSpace=wrap;fillColor=none;strokeColor=#E65100;strokeWidth=2;dashed=1;dashPattern=8 4;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="40" width="1440" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="L3_label" value="L3: Control Pipeline (NSWF allocate + ECBF filter) — runs every env step" style="text;html=1;fontSize=10;fontColor=#E65100;fontStyle=3;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="42" width="900" height="16" as="geometry"/>
        </mxCell>

        <!-- Col 1: Observe -->
        <mxCell id="c1" value="&lt;b&gt;1. Observe&lt;/b&gt;&lt;br&gt;&lt;i&gt;§3.1 · Eq.(1)&lt;/i&gt;&lt;br&gt;&lt;br&gt;x_i(t) = [MR, MA, MF]&lt;br&gt;× 6 muscles per worker&lt;br&gt;MR+MA+MF = 1&lt;br&gt;&lt;br&gt;o_i ∈ ℝ¹⁹ (local)&lt;br&gt;s ∈ ℝ^{18N+1} (global, N=6 → ℝ¹⁰⁹)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="65" width="180" height="155" as="geometry"/>
        </mxCell>

        <!-- Col 2: Allocate -->
        <mxCell id="c2" value="&lt;b&gt;2. NSWF Allocate&lt;/b&gt;&lt;br&gt;&lt;i&gt;§6 · Eq.(33)&lt;/i&gt;&lt;br&gt;&lt;br&gt;max Σ_i ln(U(i,j*(i)) − D_i)&lt;br&gt;D_i = κ·MF²/(1−MF) [Eq.32]&lt;br&gt;U(i,0) = D_i + ε [Eq.31]&lt;br&gt;κ = 1.0 · 6 tasks incl rest&lt;br&gt;→ j*(i) per worker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="260" y="65" width="190" height="155" as="geometry"/>
        </mxCell>

        <!-- Col 3: Load -->
        <mxCell id="c3" value="&lt;b&gt;3. Load Translate&lt;/b&gt;&lt;br&gt;&lt;i&gt;§7.1 · Eq.(34)&lt;/i&gt;&lt;br&gt;&lt;br&gt;j*(i) → T_L^(j) ∈ [0,1]⁶&lt;br&gt;6 tasks × 6 muscles&lt;br&gt;lookup table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="490" y="65" width="150" height="155" as="geometry"/>
        </mxCell>

        <!-- Col 4: Actor -->
        <mxCell id="c4" value="&lt;b&gt;4. Actor → C_nom&lt;/b&gt;&lt;br&gt;&lt;i&gt;§7.2 · Eq.(35)&lt;/i&gt;&lt;br&gt;&lt;br&gt;Decentralised π_θ(C | o_i, task)&lt;br&gt;2×64 Tanh, o_i ∈ ℝ¹⁹&lt;br&gt;&lt;br&gt;Baseline: C_nom = k_p·(T_L − MA)_+&lt;br&gt;k_p = 1.0 · RL replaces baseline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="65" width="195" height="155" as="geometry"/>
        </mxCell>

        <!-- Col 5: ECBF -->
        <mxCell id="c5" value="&lt;b&gt;5. ECBF Safety Filter&lt;/b&gt;&lt;br&gt;&lt;i&gt;§5 · Eq.(18),(20),(23)&lt;/i&gt;&lt;br&gt;&lt;br&gt;min ‖C − C_nom‖²  s.t.&lt;br&gt;(i) h = θ_max − MF ≥ 0  [rel-deg 2]&lt;br&gt;(ii) h₂ = MR ≥ 0  [rel-deg 1]&lt;br&gt;α₁=α₂=α₃=0.5 (config)&lt;br&gt;θ_max ≥ F/(F+Rr) [Def.5.4]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="915" y="65" width="200" height="155" as="geometry"/>
        </mxCell>

        <!-- Col 6: ODE -->
        <mxCell id="c6" value="&lt;b&gt;6. ODE → x(t+1)&lt;/b&gt;&lt;br&gt;&lt;i&gt;§3.2 · Eq.(2)–(5)&lt;/i&gt;&lt;br&gt;&lt;br&gt;dMA/dt = C* − F·MA&lt;br&gt;dMF/dt = F·MA − R_eff·MF&lt;br&gt;dMR/dt = R_eff·MF − C*&lt;br&gt;R_eff = R (work) | R·r (rest)&lt;br&gt;Euler dt = 1 min" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="1155" y="65" width="180" height="155" as="geometry"/>
        </mxCell>

        <!-- Forward arrows top row -->
        <mxCell id="a12" value="x_i(t)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c1" target="c2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a23" value="j*(i)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c2" target="c3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a34" value="T_L" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c3" target="c4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a45" value="C_nom" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c4" target="c5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a56" value="C*" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="c5" target="c6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Row 2: Reward + Buffer -->
        <mxCell id="rc" value="&lt;b&gt;7. Reward &amp; Safety Cost&lt;/b&gt;  §6, §5&lt;br&gt;R_t = Σ_i ln( U(i, j*(i)) − D_i(MF_i) )  [Eq.33, NSWF log-surplus]&lt;br&gt;C_t = Σ_{i,g} max(0, MF_{i,g} − θ_{max,i,g})  [safety cost → Lagrangian]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="260" y="290" width="450" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="buf" value="&lt;b&gt;8. Buffer Store&lt;/b&gt;&lt;br&gt;Store (o_i, s, a, log π, R_t, C_t, done)&lt;br&gt;in per-agent rollout buffer&lt;br&gt;→ Buffer sent to L4 at episode end" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="770" y="290" width="280" height="70" as="geometry"/>
        </mxCell>

        <!-- ODE down to reward -->
        <mxCell id="a6rc" value="x(t+1), MF" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#555;strokeWidth=1.3;fontSize=9;exitX=0.5;exitY=1;entryX=0.7;entryY=0;" edge="1" parent="1" source="c6" target="rc">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Reward to buffer -->
        <mxCell id="arc_buf" value="R_t, C_t" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.3;fontSize=9;" edge="1" parent="1" source="rc" target="buf">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Loop 2 feedback: ODE back to Observe -->
        <mxCell id="loop2_fb" value="Loop 2 feedback: x(t+1) → next step observation" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#C62828;strokeWidth=1.8;dashed=1;dashPattern=10 5;fontSize=9;fontColor=#C62828;exitX=1;exitY=0.5;entryX=0;entryY=1;" edge="1" parent="1" source="c6" target="c1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1420" y="142"/>
              <mxPoint x="1420" y="420"/>
              <mxPoint x="30" y="420"/>
              <mxPoint x="30" y="210"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Key correction note -->
        <mxCell id="key_note" value="&lt;b&gt;Key:&lt;/b&gt;  δ_max = R/(F+R) [sustainability bound, Eq.6] is NOT θ_max.  θ_max is a &lt;b&gt;design parameter&lt;/b&gt; with lower bound F/(F+Rr) [Def. 5.4, Eq.25]." style="text;html=1;fontSize=9;fontColor=#C62828;fontStyle=0;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="1300" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="refs" value="Math doc refs:  observation = §3.1  |  allocation = §6, Eq.31-33  |  load = §7.1, Eq.34  |  actor = §7.2, Eq.35  |  ECBF = §5, Eq.18-23  |  ODE = §3.2, Eq.2-5  |  sustainability = §3.4, Eq.6" style="text;html=1;fontSize=9;fontColor=#888;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="485" width="1300" height="18" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>