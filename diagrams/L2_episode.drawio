<mxfile host="app.diagrams.net">
  <diagram id="L2" name="L2 Episode Loop">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ==================== COLUMN 1: OBSERVATION MODULE ==================== -->
        <mxCell id="h1" value="OBSERVATION MODULE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9D9D9;strokeColor=#333;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r1a" value="&lt;b&gt;State Vector [§3.1, Eq.1]&lt;/b&gt;&lt;br&gt;• x_i(t) = [MR, MA, MF] per muscle&lt;br&gt;• 6 muscle groups per worker&lt;br&gt;• MR + MA + MF = 1 (conservation)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="20" y="50" width="220" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="r1b" value="&lt;b&gt;Local Observation&lt;/b&gt;&lt;br&gt;• o_i ∈ ℝ¹⁹ per worker&lt;br&gt;• = 6 muscles × 3 + normalised step" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="20" y="125" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r1c" value="&lt;b&gt;Global State (CTDE)&lt;/b&gt;&lt;br&gt;• s ∈ ℝ^{18N+1}&lt;br&gt;• N=6 → s ∈ ℝ¹⁰⁹&lt;br&gt;• All workers concatenated + time" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="20" y="180" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- ==================== COLUMN 2: ALLOCATION MODULE ==================== -->
        <mxCell id="h2" value="ALLOCATION MODULE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9D9D9;strokeColor=#333;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="290" y="20" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r2a" value="&lt;b&gt;NSWF Objective [§6, Eq.33]&lt;/b&gt;&lt;br&gt;• max Σ_i ln(U(i,j*(i)) − D_i(MF_i))&lt;br&gt;• Nash Social Welfare Function&lt;br&gt;• NOT Nash Bargaining [Kaneko+ 1979]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="290" y="50" width="220" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="r2b" value="&lt;b&gt;Disagreement Utility [Eq.32]&lt;/b&gt;&lt;br&gt;• D_i(MF) = κ · MF² / (1 − MF)&lt;br&gt;• κ = 1.0&lt;br&gt;• D_i → ∞ as MF → 1 (burnout guard)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="290" y="125" width="220" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="r2c" value="&lt;b&gt;Rest Option [Eq.31]&lt;/b&gt;&lt;br&gt;• U(i,0) = D_i + ε&lt;br&gt;• Surplus = ε (always feasible)&lt;br&gt;• Multiple workers may rest" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="290" y="200" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r2d" value="&lt;b&gt;Output: j*(i) per worker&lt;/b&gt;&lt;br&gt;• 1 task per worker (or rest)&lt;br&gt;• Tasks: heavy_lift, light_sort, carry,&lt;br&gt;  overhead_reach, push_cart, rest" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="290" y="270" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- ==================== COLUMN 3: CONTROL MODULE ==================== -->
        <mxCell id="h3" value="CONTROL MODULE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9D9D9;strokeColor=#333;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="560" y="20" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r3a" value="&lt;b&gt;Load Translation [§7.1, Eq.34]&lt;/b&gt;&lt;br&gt;• j*(i) → T_L^(j) ∈ [0,1]⁶&lt;br&gt;• 6 tasks × 6 muscles lookup table&lt;br&gt;• e.g. heavy_lift: shoulder=0.45,&lt;br&gt;  knee=0.40, trunk=0.50, grip=0.55" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="560" y="50" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r3b" value="&lt;b&gt;Decentralised Actor [§7.2, Eq.35]&lt;/b&gt;&lt;br&gt;• π_θ(C | o_i, task)&lt;br&gt;• 2×64 Tanh, input o_i ∈ ℝ¹⁹&lt;br&gt;• Baseline: C_nom = k_p·(T_L − MA)_+&lt;br&gt;• k_p = 1.0&lt;br&gt;• RL policy replaces baseline" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="560" y="140" width="220" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="r3c" value="&lt;b&gt;ECBF Safety Filter = Loop 3 (L3)&lt;/b&gt;&lt;br&gt;• CBF-QP per muscle per worker [Eq.20]&lt;br&gt;• (i) h = θ_max − MF ≥ 0 [rel-deg 2, Eq.18]&lt;br&gt;• (ii) h₂ = MR ≥ 0 [rel-deg 1, Eq.23]&lt;br&gt;• α₁=α₂=α₃=0.5 (config)&lt;br&gt;• θ_max ≥ F/(F+Rr) [Def.5.4, Eq.25]&lt;br&gt;• QP infeasible → C*=0 (forced rest)&lt;br&gt;• See Figure L3 for detail" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="560" y="240" width="220" height="130" as="geometry"/>
        </mxCell>

        <!-- ==================== COLUMN 4: DYNAMICS MODULE ==================== -->
        <mxCell id="h4" value="DYNAMICS MODULE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9D9D9;strokeColor=#333;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="830" y="20" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r4a" value="&lt;b&gt;3CC-r ODE Integration [§3.2]&lt;/b&gt;&lt;br&gt;• dMA/dt = C* − F·MA [Eq.2]&lt;br&gt;• dMF/dt = F·MA − R_eff·MF [Eq.3]&lt;br&gt;• dMR/dt = R_eff·MF − C* [Eq.4]&lt;br&gt;• Euler step, dt = 1 min" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="830" y="50" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r4b" value="&lt;b&gt;Reperfusion Switch [§3.3, Eq.5]&lt;/b&gt;&lt;br&gt;• R_eff = R (work phase)&lt;br&gt;• R_eff = R·r (rest phase)&lt;br&gt;• r = 15 (shoulder/ankle/knee/elbow/trunk)&lt;br&gt;• r = 30 (grip)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="830" y="140" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r4c" value="&lt;b&gt;Output: x(t+1)&lt;/b&gt;&lt;br&gt;• Updated [MR, MA, MF] per muscle&lt;br&gt;• → feeds back to Observation Module&lt;br&gt;  (next step of Loop 2)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="830" y="230" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- ==================== COLUMN 5: REWARD & BUFFER MODULE ==================== -->
        <mxCell id="h5" value="REWARD &amp; BUFFER MODULE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D9D9D9;strokeColor=#333;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1100" y="20" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r5a" value="&lt;b&gt;Reward [§6, Eq.33]&lt;/b&gt;&lt;br&gt;• R_t = Σ_i ln(U(i,j*(i)) − D_i(MF_i))&lt;br&gt;• = NSWF log-surplus by construction&lt;br&gt;• RL return = Nash surplus product" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1100" y="50" width="220" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="r5b" value="&lt;b&gt;Safety Cost&lt;/b&gt;&lt;br&gt;• C_t = Σ_{i,g} max(0, MF_{i,g} − θ_{max,i,g})&lt;br&gt;• Per-muscle threshold violation&lt;br&gt;• → Lagrangian penalty in L4" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1100" y="125" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r5c" value="&lt;b&gt;Rollout Buffer Store&lt;/b&gt;&lt;br&gt;• (o_i, s, a, log π, R_t, C_t, done)&lt;br&gt;• Per-agent storage&lt;br&gt;• T×N samples per episode&lt;br&gt;→ Sent to L4 at episode end" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1100" y="195" width="220" height="85" as="geometry"/>
        </mxCell>

        <!-- ==================== ARROWS ==================== -->
        <mxCell id="a12a" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r1a" target="r2a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a12b" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r1b" target="r2b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a23a" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r2d" target="r3a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a34a" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" edge="1" parent="1" source="r3c" target="r4a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a45a" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r4c" target="r5a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== CAPTION ==================== -->
        <mxCell id="cap" value="&lt;b&gt;Figure L2:&lt;/b&gt; Schematic framework of the episode loop (Loop 2, inside Loop 1). Each env step proceeds left-to-right: observe physiological state (§3.1), NSWF-allocate tasks (§6), translate loads (§7.1), compute actor's nominal drive (§7.2), safety-filter via dual-barrier ECBF-QP (§5) = Loop 3, integrate 3CC-r ODEs (§3.2), then compute NSWF-derived reward and safety cost. The buffer stores transitions for Loop 4 (PPO update). Key: δ_max = R/(F+R) [Eq.6] is the sustainability bound, NOT θ_max. θ_max is a design parameter with lower bound F/(F+Rr) [Def. 5.4, Eq.25]." style="text;html=1;fontSize=9;align=left;verticalAlign=top;spacingLeft=5;spacingTop=3;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="20" y="410" width="1300" height="50" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>