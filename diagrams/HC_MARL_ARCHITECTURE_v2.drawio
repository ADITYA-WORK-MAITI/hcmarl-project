        <mxCell id="a78" value="C_nom" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#222;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="b7" target="b8">
          <mxGeometry relative="1" as="geometry" />
