        <mxCell id="loop1_label" value="Loop 1&#xa;(env step)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontStyle=2;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="762" y="460" width="60" height="30" as="geometry" />
        </mxCell>
