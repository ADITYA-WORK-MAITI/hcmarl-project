          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a34" value="Θ_max(z), τ demos" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#222;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="b3" target="b4">
          <mxGeometry relative="1" as="geometry" />
