        <!-- Arrow from env-step into logger (lateral, one jump only) -->
        <mxCell id="a9_log" value="episode metrics" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#555;strokeWidth=1.2;fontSize=9;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="b10" target="logger">
