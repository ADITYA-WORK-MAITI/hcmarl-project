        <mxCell id="a9_10" value="x(t+1), MF, tasks" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#222;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="b9" target="b10">
