<mxfile host="app.diagrams.net" modified="2026-04-14T00:00:00.000Z" agent="claude-code" version="24.0.0">
  <diagram id="hcmarl-main" name="HC-MARL Architecture">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== PHASE BACKGROUND PANELS ===== -->
        <mxCell id="phase_calib" value="CALIBRATION  (offline, pre-training)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF5CC;strokeColor=#B8860B;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;opacity=70;" vertex="1" parent="1">
          <mxGeometry x="260" y="40" width="520" height="220" as="geometry" />
        </mxCell>
        <mxCell id="phase_ctrl" value="CONTROL / ENV LOOP  (Loop 1: per-step)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F0FF;strokeColor=#1F4E79;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;opacity=70;" vertex="1" parent="1">
          <mxGeometry x="260" y="270" width="520" height="400" as="geometry" />
        </mxCell>
        <mxCell id="phase_learn" value="LEARNING  (Loop 2: per-batch)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F5E1;strokeColor=#2E7D32;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;opacity=70;" vertex="1" parent="1">
          <mxGeometry x="260" y="680" width="520" height="180" as="geometry" />
        </mxCell>

        <!-- ===== TITLE ===== -->
        <mxCell id="title" value="HC-MARL · End-to-End Architecture  (v2, math-verified)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="8" width="1420" height="24" as="geometry" />
        </mxCell>

        <!-- ===== MAIN SPINE BOXES ===== -->
        <!-- Row 1: Real Dataset -->
        <mxCell id="b1" value="&lt;b&gt;1. Real Dataset · WSD4FESDRM&lt;/b&gt;&lt;br&gt;34 subj · Borg-RPE-20 shoulder rotation · 30–60% MVIC&lt;br&gt;Zenodo 8415066 · Sci. Data 2024" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B8860B;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="60" width="470" height="55" as="geometry" />
        </mxCell>
        <!-- Row 2: Calibration -->
        <mxCell id="b2" value="&lt;b&gt;2. 3CC-r Calibration (Path G)&lt;/b&gt;  §3.5 · Eq.(6)&lt;br&gt;Grid-search (F,R) per subject to match ET_obs&lt;br&gt;Shoulder 0.0146/0.00058 · Ankle 0.00589/0.0182 · Knee 0.0150/0.00175 · Elbow 0.00912/0.00094 · &lt;b&gt;Trunk 0.00657/0.00354&lt;/b&gt; · Grip 0.00794/0.00109 (r=15, grip r=30)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B8860B;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="125" width="470" height="65" as="geometry" />
        </mxCell>
        <!-- Row 3: MMICRL -->
        <mxCell id="b3" value="&lt;b&gt;3. MMICRL · Multi-Modal Inv. Constrained RL&lt;/b&gt;  §4 · Eq.(9)–(11)&lt;br&gt;Obj: λ₁H[π(τ)] − λ₂H[π(τ|z)]  → recommend λ₁=λ₂ (pure MI)&lt;br&gt;CFDE normalising flows (MADE/MAF) conditioned on z  →  personalised Θ_max per type" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B8860B;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="200" width="470" height="55" as="geometry" />
        </mxCell>

        <!-- Row 4: State Observation (env loop start) -->
        <mxCell id="b4" value="&lt;b&gt;4. State Observation&lt;/b&gt;  §3.1 · Eq.(1)&lt;br&gt;x_i(t) = [MR, MA, MF] per muscle · MR+MA+MF = 1&lt;br&gt;Local o_i ∈ ℝ¹⁹ (6·3 + t) · Global s ∈ ℝ^{18N+1} (N=6 → ℝ¹⁰⁹)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F4E79;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="290" width="470" height="60" as="geometry" />
        </mxCell>
        <!-- Row 5: NSWF Allocator -->
        <mxCell id="b5" value="&lt;b&gt;5. NSWF Task Allocator (central planner)&lt;/b&gt;  §6 · Eq.(33)&lt;br&gt;max_{a_{ij}} Σ_i ln( U(i, j*(i)) − D_i(MF_i) )  ·  D_i = κ·MF² / (1−MF)  [Eq.32]&lt;br&gt;Rest option U(i,0) = D_i + ε  [Eq.31] · κ=1.0 · tasks = {heavy_lift, light_sort, carry, overhead_reach, push_cart, rest}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F4E79;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="360" width="470" height="60" as="geometry" />
        </mxCell>
        <!-- Row 6: Load Translation -->
        <mxCell id="b6" value="&lt;b&gt;6. Load Translation&lt;/b&gt;  §7.1 · Eq.(34)&lt;br&gt;j*(i) → T_L^(j) ∈ [0,1]⁶  (6 tasks × 6 muscles lookup table)&lt;br&gt;e.g. heavy_lift = (shoulder 0.45, knee 0.40, trunk 0.50, grip 0.55, …)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F4E79;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="430" width="470" height="55" as="geometry" />
        </mxCell>
        <!-- Row 7: Decentralised Actor -->
        <mxCell id="b7" value="&lt;b&gt;7. Decentralised Actor  π_θ(C | o_i, task)&lt;/b&gt;  §7.2 · Eq.(35)&lt;br&gt;Baseline C_nom = k_p·(T_L − MA)_+ , k_p=1.0  →  RL replaces baseline: C_nom = f_θ(x, task)&lt;br&gt;2×64 Tanh · input o_i ∈ ℝ¹⁹ (local only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F4E79;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="495" width="470" height="55" as="geometry" />
        </mxCell>
        <!-- Row 8: ECBF Safety Filter -->
        <mxCell id="b8" value="&lt;b&gt;8. ECBF Safety Filter · CBF-QP (dual barrier)&lt;/b&gt;  §5 · Eq.(18),(20),(23)&lt;br&gt;min_C ‖C − C_nom‖²  s.t.  (i) h = Θ_max − MF ≥ 0  [rel-deg 2 → ECBF]  (ii) h₂ = MR ≥ 0  [rel-deg 1 → CBF]&lt;br&gt;α₁=α₂=α₃=0.5 (config) · Θ_max ≥ F/(F+Rr)  [Def. 5.4, Eq.25] · personalised per worker from MMICRL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F4E79;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="560" width="470" height="60" as="geometry" />
        </mxCell>
        <!-- Row 9: ODE Integration -->
        <mxCell id="b9" value="&lt;b&gt;9. 3CC-r ODE Integration  →  x(t+1)&lt;/b&gt;  §3.2 · Eq.(2)–(5)&lt;br&gt;dMA/dt = C* − F·MA · dMF/dt = F·MA − R_eff·MF · dMR/dt = R_eff·MF − C*&lt;br&gt;R_eff = R (work) / R·r (rest)  ·  Euler dt = 1 min  ·  sustainability: δ_max = R/(F+R), C_max = FR/(F+R)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F4E79;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="630" width="470" height="35" as="geometry" />
        </mxCell>

        <!-- Row 10: Reward + Cost -->
        <mxCell id="b10" value="&lt;b&gt;10. Reward &amp; Safety Cost&lt;/b&gt;  §6,§5 · Eq.(33), Eq.(12)&lt;br&gt;R_t = Σ_i ln( U(i, j*(i)) − D_i(MF_i) )   [= NSWF log-surplus, by construction]&lt;br&gt;C_t = Σ_{i,g} max(0, MF_{i,g} − Θ_{max,i,g})  [safety-cost signal to Lagrangian]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="700" width="470" height="55" as="geometry" />
        </mxCell>
        <!-- Row 11: Learner -->
        <mxCell id="b11" value="&lt;b&gt;11. Centralised Learner · MAPPO-Lagrangian&lt;/b&gt;  (Correction C.f. Achiam+ '17, CMDP)&lt;br&gt;V_φ(s): 2×128 Tanh, GAE γ=0.99 λ=0.95  ·  V_c(s): cost-critic  ·  log λ ∈ nn.Parameter (dual ascent)&lt;br&gt;L_actor = −min(rÂ, clip(r,1±0.2)Â) + λ·max(ĉ_r1, ĉ_r2) − 0.01·H  ·  batch 256 · epochs 10 · lr 3e-4 · 5M steps · 5 seeds" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="285" y="765" width="470" height="70" as="geometry" />
        </mxCell>

        <!-- ===== LEFT SIDE: 9-METRIC LOGGER + LEGEND + CAPTION ===== -->
        <mxCell id="logger" value="&lt;b&gt;9-Metric Episode Logger&lt;/b&gt;&lt;br&gt;&lt;br&gt;O1 violation_rate&lt;br&gt;O2 safety_rate&lt;br&gt;O3 jain_fairness&lt;br&gt;O4 tasks_completed&lt;br&gt;O5 cum_reward&lt;br&gt;O6 peak_fatigue&lt;br&gt;O7 forced_rest_rate&lt;br&gt;O8 constraint_recovery_t&lt;br&gt;O9 cum_cost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#555;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="200" height="190" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;━━  forward data / control&lt;br&gt;━ ━  Loop 1: env state feedback&lt;br&gt;╍╍╍  Loop 2: gradient feedback&lt;br&gt;&lt;br&gt;&lt;b&gt;Phases&lt;/b&gt;&lt;br&gt;■ yellow = offline calibration&lt;br&gt;■ blue = online env loop&lt;br&gt;■ green = policy learning&lt;br&gt;&lt;br&gt;§X = math-doc section ref" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#555;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="200" height="180" as="geometry" />
        </mxCell>

        <mxCell id="footnote" value="&lt;b&gt;Notes&lt;/b&gt;&lt;br&gt;• α₁=α₂=α₃=0.5 in config.&lt;br&gt;  Env currently hardcodes&lt;br&gt;  (0.05, 0.05, 0.10) — flagged.&lt;br&gt;• Θ_max is a &lt;i&gt;design&lt;/i&gt; parameter&lt;br&gt;  (not = δ_max). Lower bound:&lt;br&gt;  Θ_max ≥ F/(F+Rr)  [Eq.25].&lt;br&gt;• N = n_workers (6 default)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#C67C00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="200" height="155" as="geometry" />
        </mxCell>

        <!-- ===== RIGHT SIDE: EQUATION SHEET ===== -->
        <mxCell id="eqsheet" value="&lt;b&gt;Equation Sheet  (referenced by §)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;§3 Physiology (3CC-r)&lt;/b&gt;&lt;br&gt;(1)  MR + MA + MF = 1&lt;br&gt;(2)  dMA/dt = C − F·MA&lt;br&gt;(3)  dMF/dt = F·MA − R_eff·MF&lt;br&gt;(4)  dMR/dt = R_eff·MF − C&lt;br&gt;(5)  R_eff = R (work) | R·r (rest)&lt;br&gt;(6)  δ_max = R/(F+R) ;  C_max = FR/(F+R)&lt;br&gt;&lt;br&gt;&lt;b&gt;§4 MMICRL&lt;/b&gt;&lt;br&gt;(9)   max_π  λ₁H[π(τ)] − λ₂H[π(τ|z)]&lt;br&gt;(10)  = λ₂ I(τ;z) + (λ₁−λ₂)H[π(τ)]&lt;br&gt;(11)  λ₁=λ₂ ⇒ pure MI maximisation&lt;br&gt;&lt;br&gt;&lt;b&gt;§5 ECBF (dual barrier)&lt;/b&gt;&lt;br&gt;(12)  h(x) = Θ_max − MF ≥ 0&lt;br&gt;(18)  −F·C + F²MA + R_eff·F·MA − R_eff²·MF &lt;br&gt;         + α₁·h + α₂·ψ₁ ≥ 0   [rel-deg 2]&lt;br&gt;(20)  C* = argmin ‖C − C_nom‖²  s.t. (18),(23),C≥0&lt;br&gt;(21)  h₂(x) = MR = 1 − MA − MF ≥ 0&lt;br&gt;(23)  C ≤ R_eff·MF + α₃·(1 − MA − MF)&lt;br&gt;(25)  Θ_max ≥ Θ_max^min = F / (F + R·r)   [Def. 5.4]&lt;br&gt;(29)  Δt* ≥ F⁻¹·ln( F·MA(t_s) / β(t_r) )_+&lt;br&gt;&lt;br&gt;&lt;b&gt;§6 NSWF Allocation&lt;/b&gt;&lt;br&gt;(31)  U(i,0) = D_i + ε    (rest option)&lt;br&gt;(32)  D_i(MF) = κ · MF² / (1 − MF)&lt;br&gt;(33)  max_{a_{ij}} Σ_i ln( U(i,j*(i)) − D_i(MF_i) )&lt;br&gt;&lt;br&gt;&lt;b&gt;§7 Interface&lt;/b&gt;&lt;br&gt;(34)  T_L^{(j)}_g ∈ [0,1]  (task-g MVC demand)&lt;br&gt;(35)  C(t) = k_p·(T_L − MA)_+   (baseline controller)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="830" y="40" width="640" height="820" as="geometry" />
        </mxCell>

        <!-- ===== FORWARD ARROWS (orthogonal, centred) ===== -->
        <mxCell id="a12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#222;strokeWidth=1.5;" edge="1" parent="1" source="b1" target="b2">
          <mxGeometry relative="1" as="geometry" />
