# ============================================================
# HC-MARL .gitignore
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.pytest_cache/

# ---------- Virtual environments ----------
venv/
.venv/
env/

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- IDE ----------
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- Experiment outputs ----------
checkpoints/
results/
figures/*.png
wandb/

# ---------- Large files ----------
*.pt
*.pth
*.ckpt
*.npy
*.npz

# ---------- Datasets (large, download separately) ----------
data/

# ---------- Reference PDFs (large, local only) ----------
REFERENCES/

# ---------- Training run logs (generated, not source) ----------
logs/hcmarl/
logs/mappo/
logs/mappo_lag/
logs/ippo/
logs/ppo_lag/
logs/cpo/
logs/macpo/

# ---------- Notebook outputs (generated) ----------
notebooks/*_executed.ipynb
notebooks/*.png

# ---------- LaTeX ----------
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls

# ---------- Secrets ----------
.env
*.key

# ---------- Scratch text extractions (session artifacts, not source) ----------
_*_text.txt

# ---------- Experiment result folders (build artifacts, never commit) ----------
Results 0/
Results 1/
Results 2/
Results 3/
Results 4/
*.bak
logs_exp1_mirror/
checkpoints_exp1_mirror/
