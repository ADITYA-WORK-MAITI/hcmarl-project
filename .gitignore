# ============================================================
# HC-MARL .gitignore
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ---------- Virtual environments ----------
venv/
.venv/
env/

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- IDE ----------
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- Experiment outputs ----------
checkpoints/
results/
figures/*.png
wandb/

# ---------- Large files ----------
*.pt
*.pth
*.ckpt
*.npy
*.npz

# ---------- Datasets (large, download separately) ----------
data/

# ---------- Reference PDFs (large, local only) ----------
REFERENCES/

# ---------- Training run logs (generated, not source) ----------
logs/hcmarl/
logs/mappo/
logs/mappo_lag/
logs/ippo/
logs/ppo_lag/
logs/cpo/
logs/macpo/

# ---------- Notebook outputs (generated) ----------
notebooks/*_executed.ipynb
notebooks/*.png

# ---------- LaTeX ----------
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls

# ---------- Secrets ----------
.env
*.key
